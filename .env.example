# Supabase project credentials (safe to expose client-side — RLS enforces access)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
# Optional: set to false to call hosted edge functions directly in local dev.
VITE_SUPABASE_FUNCTIONS_PROXY=true
# Optional: point local dev at a local edge-function base URL instead of the hosted project.
# Example: http://127.0.0.1:54331/functions/v1
VITE_SUPABASE_FUNCTIONS_URL=
