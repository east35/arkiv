# Local edge-function runtime configuration.
# Copy to .env.functions.local and fill in the secrets needed by the functions you want to run.

# Local aggregator URL used by the frontend via VITE_SUPABASE_FUNCTIONS_URL.
FUNCTIONS_PROXY_PORT=54331

# Comma-separated function names to run locally.
# Default recommendation for this repo: IGDB + Hardcover + bookmark metadata.
# Add ai-chat-proxy when testing item-level AI discussion locally.
LOCAL_FUNCTIONS=igdb-proxy,hardcover-proxy,bookmark-metadata

# Hosted Supabase credentials used by functions that validate auth tokens.
# Defaults to the VITE_* values from .env.local if omitted.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# External API secrets
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
HARDCOVER_API_KEY=
# Optional only if you explicitly add google-books-proxy to LOCAL_FUNCTIONS.
GOOGLE_BOOKS_API_KEY=

# Optional: extra local origins to allow while testing functions directly.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
